{
    "name": "logged-cloud/caddy-studio",
    "description": "Visual node-based config editor for Caddy. Drag domains to upstreams, split through load balancers, compile the graph to Caddy admin JSON, apply it, and get alerted when the live server drifts.",
    "keywords": ["laravel", "livewire", "alpine", "caddy", "reverse-proxy", "node-graph", "config-editor"],
    "license": "FSL-1.1-MIT",
    "authors": [
        {"name": "Charles Lennon"}
    ],
    "homepage": "https://github.com/Logged-Cloud/caddy-studio",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0 || ^12.0 || ^13.0",
        "illuminate/database": "^11.0 || ^12.0 || ^13.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "orchestra/testbench": "^9.0 || ^10.0 || ^11.0",
        "livewire/livewire": "^3.0 || ^4.0"
    },
    "suggest": {
        "livewire/livewire": "Required to use the bundled Livewire builder component (^3.0 || ^4.0)."
    },
    "autoload": {
        "psr-4": {
            "LoggedCloud\\CaddyStudio\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LoggedCloud\\CaddyStudio\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "pest"
    },
    "extra": {
        "laravel": {
            "providers": [
                "LoggedCloud\\CaddyStudio\\CaddyStudioServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
